{
  "name": "signalk-duckdb-ui",
  "version": "0.1.0",
  "description": "DuckDB SQL UI for SignalK data — supports parquet archives and extensible data sources",
  "main": "dist/index.js",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "signalk-category-data",
    "duckdb",
    "parquet",
    "sql",
    "marine-data"
  ],
  "scripts": {
    "build": "tsc && cp -r src/ui dist/ui",
    "watch": "tsc --watch",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "@signalk/server-api": "^2.22.0",
    "express": "^4.18.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT"
}
